---
interface Props {
  alt?: string;
  class?: string;
  valign?: string;
}

const { alt, class: className, valign } = Astro.props;
const style = valign ? `vertical-align: ${valign}; display: inline-block;` : "display: inline-block;";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  height="20"
  fill="none"
  viewBox="0 0 24 24"
  stroke-width="1.5"
  stroke="currentColor"
  class={className}
  role={alt ? "img" : undefined}
  aria-label={alt}
  style={style}
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
  />
</svg>
