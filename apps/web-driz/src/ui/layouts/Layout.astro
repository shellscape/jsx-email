---
interface Props {
  title?: string;
}

const { title = "jsx.email - Building Emails doesn't have to be Painful" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Build and send emails using JSX with a delightful developer experience"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      const starlightTheme = localStorage.getItem('starlight-theme');
      const savedTheme = starlightTheme || localStorage.getItem('theme') || 'system';
      const normalizedTheme = savedTheme === 'auto' ? 'system' : savedTheme;
      const resolvedTheme =
        normalizedTheme === 'system'
          ? window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light'
          : normalizedTheme;

      document.documentElement.classList.toggle('dark', resolvedTheme === 'dark');
      document.documentElement.classList.toggle('light', resolvedTheme !== 'dark');
      document.documentElement.style.colorScheme = resolvedTheme;
    </script>
  </head>
  <body class="bg-white dark:bg-black text-black dark:text-white font-sans antialiased">
    <slot />

    <script is:inline>
      const themeCycle = ['light', 'dark', 'system'];
      const prefersDarkQuery = window.matchMedia('(prefers-color-scheme: dark)');

      function getStoredTheme() {
        const storedTheme = localStorage.getItem('theme') || localStorage.getItem('starlight-theme');
        return storedTheme === 'auto' ? 'system' : storedTheme || 'system';
      }

      function getResolvedTheme(theme) {
        if (theme === 'system') {
          return prefersDarkQuery.matches ? 'dark' : 'light';
        }

        return theme;
      }

      function getNextTheme(theme) {
        return themeCycle[(themeCycle.indexOf(theme) + 1) % themeCycle.length];
      }

      function applyTheme(theme) {
        const resolvedTheme = getResolvedTheme(theme);

        document.documentElement.classList.toggle('dark', resolvedTheme === 'dark');
        document.documentElement.classList.toggle('light', resolvedTheme !== 'dark');
        document.documentElement.style.colorScheme = resolvedTheme;
      }

      function updateThemeToggle(theme = getStoredTheme()) {
        const themeToggle = document.getElementById('theme-toggle');
        if (!themeToggle) return;

        const nextTheme = getNextTheme(theme);
        themeToggle.title = `Switch to ${nextTheme[0].toUpperCase()}${nextTheme.slice(1)} Mode`;
        themeToggle.setAttribute('aria-label', themeToggle.title);

        document.querySelectorAll('[data-theme-toggle-icon]').forEach((icon) => {
          icon.classList.toggle('hidden', icon.dataset.themeToggleIcon !== nextTheme);
        });
      }

      function setHomepageTheme(theme) {
        localStorage.setItem('theme', theme);
        localStorage.setItem('starlight-theme', theme);
        applyTheme(theme);
        updateThemeToggle(theme);
      }

      function cycleTheme() {
        setHomepageTheme(getNextTheme(getStoredTheme()));
      }

      document.addEventListener('DOMContentLoaded', () => {
        const themeToggle = document.getElementById('theme-toggle');
        if (themeToggle) {
          themeToggle.addEventListener('click', cycleTheme);
        }

        applyTheme(getStoredTheme());
        updateThemeToggle();
      });

      window.addEventListener('storage', (e) => {
        if (e.key === 'starlight-theme' || e.key === 'theme') {
          const newTheme = e.newValue === 'auto' ? 'system' : e.newValue || 'system';
          applyTheme(newTheme);
          updateThemeToggle(newTheme);
        }
      });

      prefersDarkQuery.addEventListener('change', () => {
        if (getStoredTheme() === 'system') {
          applyTheme('system');
          updateThemeToggle('system');
        }
      });
    </script>
  </body>
</html>
