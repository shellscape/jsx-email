---
import Logo from './Logo.astro';
import { Discord, X } from "iconoir-react";

interface Props {
  isCenteredLayout?: boolean;
}

const { isCenteredLayout } = Astro.props;
---

<div class:list={['wrap', isCenteredLayout && 'wrap-centered']}>
  <div class="container">
    <div class="content">
      <div class="logo-container">
        <div>
          <Logo />
          <p>Build and send emails with JSX.</p>
        </div>
        <div class="social-media-container">
          <a
            target="_blank"
            href="https://github.com/shellscape/jsx-email"
            aria-label="JSX email GitHub"
            rel="nofollow noreferrer"
          >
            <svg width="24" height="24" fill="currentColor" viewBox="3 3 18 18">
              <title>GitHub</title>
              <path
                d="M12 3C7.0275 3 3 7.12937 3 12.2276C3 16.3109 5.57625 19.7597 9.15374 20.9824C9.60374 21.0631 9.77249 20.7863 9.77249 20.5441C9.77249 20.3249 9.76125 19.5982 9.76125 18.8254C7.5 19.2522 6.915 18.2602 6.735 17.7412C6.63375 17.4759 6.19499 16.6569 5.8125 16.4378C5.4975 16.2647 5.0475 15.838 5.80124 15.8264C6.51 15.8149 7.01625 16.4954 7.18499 16.7723C7.99499 18.1679 9.28875 17.7758 9.80625 17.5335C9.885 16.9337 10.1212 16.53 10.38 16.2993C8.3775 16.0687 6.285 15.2728 6.285 11.7432C6.285 10.7397 6.63375 9.9092 7.20749 9.26326C7.1175 9.03257 6.8025 8.08674 7.2975 6.81794C7.2975 6.81794 8.05125 6.57571 9.77249 7.76377C10.4925 7.55615 11.2575 7.45234 12.0225 7.45234C12.7875 7.45234 13.5525 7.55615 14.2725 7.76377C15.9937 6.56418 16.7475 6.81794 16.7475 6.81794C17.2424 8.08674 16.9275 9.03257 16.8375 9.26326C17.4113 9.9092 17.76 10.7281 17.76 11.7432C17.76 15.2843 15.6563 16.0687 13.6537 16.2993C13.98 16.5877 14.2613 17.1414 14.2613 18.0065C14.2613 19.2407 14.25 20.2326 14.25 20.5441C14.25 20.7863 14.4188 21.0746 14.8688 20.9824C16.6554 20.364 18.2079 19.1866 19.3078 17.6162C20.4077 16.0457 20.9995 14.1611 21 12.2276C21 7.12937 16.9725 3 12 3Z"
              ></path>
            </svg>
          </a>
          <a
            target="_blank"
            href="https://discord.gg/FywZN57mTg"
            aria-label="JSX email Discord"
            rel="nofollow noreferrer"
          >
            <Discord width="24" height="24" strokeWidth={1.75} />
          </a>
        </div>
      </div>
      <div class="link-container">
        <div>
          <div class="link-group-title">Documentation</div>
          <div>
            <a class="link-group-item" href="/docs/introduction">Introduction</a>
            <a class="link-group-item" href="/docs/quick-start">Quick Start</a>
            <a class="link-group-item" href="/docs/components/background">Components</a>
            <a class="link-group-item" href="/docs/core/render">Render API</a>
          </div>
        </div>
        <div>
          <div class="link-group-title">Resources</div>
          <div>
            <a class="link-group-item" href="/blocks">Blocks</a>
            <a class="link-group-item" href="http://samples.jsx.email" target="_blank" rel="noreferrer">Samples</a>
            <a class="link-group-item" href="https://pro.jsx.email" target="_blank" rel="noreferrer">Pro Templates</a>
          </div>
        </div>
        <div>
          <div class="link-group-title">Learn</div>
          <div>
            <a class="link-group-item" href="/docs/recipes">Recipes</a>
            <a class="link-group-item" href="/docs/faq">FAQ</a>
            <a class="link-group-item" href="/docs/contributing">Contributing</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  html[class~='dark'] .wrap {
    color: #f3f4f6;
  }

  .wrap {
    width: calc(100% + 48px);
    margin-left: -24px;
    margin-right: -24px;
    border-top: 1px solid #ececec;
    color: rgb(0, 0, 0);
  }

  .wrap-centered {
    width: 100%;
    margin-left: 0px;
    margin-right: 0px;
  }

  html[class~='dark'] .wrap {
    border-top: 1px solid #2a2a2a;
  }

  .container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 12px 24px 36px;
    display: grid;
    gap: 64px;
  }

  .content {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .logo-container {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .logo-container p {
    font-size: 14px;
    margin-top: 2px;
  }

  .link-container {
    display: flex;
    gap: 32px 64px;
  }

  .link-group-title {
    font-weight: 600;
    font-size: 18px;
    margin-top: 12px;
  }

  .link-group-item {
    width: fit-content;
    display: block;
    font-size: 14px;
    margin-top: 8px;
    text-decoration: none;
    color: currentColor;
  }

  .link-group-item:first-child {
    margin-top: 14px;
  }

  .social-media-container {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .social-media-container a {
    padding: 0.25rem;
    color: currentColor;
  }

  @media screen and (max-width: 768px) {
    .wrap {
      display: block;
    }

    .content {
      display: grid;
      gap: 48px;
    }

    .link-container {
      display: flex;
      flex-wrap: wrap;
    }
  }
</style>
