---
import '../styles/home.css';

import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import Layout from '@/ui/layouts/Layout.astro';
---

<Layout title="JSX email - Build beautiful emails with JSX">
  <Header />
  <main>
    <div class="wrap">
      <div class="not-found" aria-hidden="true"></div>
      <div class="content">
        <div class="actions" aria-label="404 navigation">
          <button
            class="back-action inline-flex min-h-[44px] items-center justify-center rounded-[6px] px-6 py-3 font-semibold no-underline transition-colors cursor-pointer"
            type="button"
            data-history-back
          >
            Back from whence ye came
          </button>
          <a
            href="/"
            class="inline-flex min-h-[44px] items-center justify-center rounded-[6px] border border-gray-300 bg-white px-6 py-3 font-semibold text-gray-900 no-underline transition-colors hover:border-gray-400 hover:bg-gray-100"
            >Take me home</a
          >
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.querySelector("[data-history-back]")?.addEventListener("click", () => {
    history.back();
  });
</script>

<style>
  .wrap {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 4vw, 40px);
    justify-content: center;
    margin: 0;
    min-height: calc(100svh - 160px);
    overflow: hidden;
    padding: clamp(72px, 10vw, 112px) 24px clamp(48px, 8vw, 96px);
  }

  .not-found {
    aspect-ratio: 3 / 2;
    background-image: url("/assets/404.png");
    background-position: center;
    background-repeat: no-repeat;
    background-size: 150%;
    max-width: 100%;
    width: min(100%, 960px, 76svh);
  }

  .content {
    display: grid;
    place-items: center;
    width: 100%;
  }

  .actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    padding: 0 16px;
  }

  .back-action {
    background: #24292e;
    border: 1px solid #111827;
    color: #fff;
  }

  .back-action:hover {
    background: #000;
    border-color: #374151;
  }

  @media (max-width: 520px) {
    .actions > * {
      width: min(100%, 18rem);
    }
  }
</style>
