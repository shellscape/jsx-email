---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <ThemeSelect />
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <LanguageSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      align-items: center;
      height: 100%;
      width: 100%;
      max-width: 1536px;
      margin-inline: auto;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group,
    .social-icons {
      gap: 1rem;
      align-items: center;
    }

    .header > .sl-flex:not(.title-wrapper):not(.right-group) {
      flex: 1 1 auto;
      justify-content: center;
      min-width: 0;
    }
  }
</style>

<style is:global>
  @layer starlight.core {
    :root {
      --sl-nav-height: 4.25rem;
      --sl-nav-pad-x: 1rem;
      --sl-nav-pad-y: 1rem;
    }

    @media (min-width: 50rem) {
      :root {
        --sl-nav-pad-x: 1.5rem;
      }
    }

    .page > header.header {
      background-color: var(--bg);
      border-bottom-color: var(--border);
      padding: 1rem;
      padding-inline-end: calc(1rem + var(--sl-menu-button-size) + 1rem);
    }

    [data-has-sidebar] .page > header.header {
      padding-inline-end: calc(1rem + var(--sl-menu-button-size) + 1rem);
    }

    .page > header.header .site-title img {
      height: 2.25rem;
    }

    .page > header.header .site-title {
      color: var(--sl-color-text);
      gap: 0;
    }

    @media (min-width: 48rem) {
      .page > header.header,
      [data-has-sidebar] .page > header.header {
        padding-inline: 1.5rem;
      }
    }

    .page > header.header button[data-open-modal] {
      color: var(--text-subtle);
    }

    .page > header.header button[data-open-modal]:hover {
      color: var(--text-strong);
    }

    @media (min-width: 50rem) {
      .page > header.header button[data-open-modal] {
        background-color: transparent;
        border-color: var(--border);
        border-radius: var(--radius);
      }

      .page > header.header button[data-open-modal]:hover {
        background-color: var(--surface);
        border-color: var(--border-soft);
      }
    }

    starlight-menu-button button {
      border-radius: var(--radius);
      background-color: transparent;
      color: var(--text-subtle);
      box-shadow: none;
    }

    starlight-menu-button button:hover {
      background-color: var(--surface);
      color: var(--text-strong);
    }
  }
</style>
