---
import Default from '@astrojs/starlight/components/PageFrame.astro';
import SiteFooter from './SiteFooter.astro';
---

<Default {...Astro.props}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>

<div class="print:hidden">
  <script is:inline>
    document.documentElement.classList.toggle(
      'dark',
      document.documentElement.dataset.theme === 'dark'
    );
  </script>
  <SiteFooter />
</div>

<style is:global>
  @layer starlight.core {
    .page > header.header {
      border-bottom-color: transparent;
    }

    .content-panel + .content-panel {
      border-top: 0;
    }

    @media (min-width: 50rem) {
      .sidebar-pane {
        border-inline-end: 0 !important;
        background-color: var(--bg);
      }
    }

    @media (min-width: 72rem) {
      .content-panel {
        border-inline-end: 0 !important;
      }

      .right-sidebar {
        border-inline-start: 0 !important;
      }
    }

    .sidebar-content {
      background-color: transparent;
    }

    .sl-markdown-content a:not(:where(.not-content *)) {
      color: var(--link-accent);
      text-decoration: none;
      transition: color 150ms;
    }

    .sl-markdown-content a:hover:not(:where(.not-content *)),
    .sl-markdown-content a:focus-visible:not(:where(.not-content *)) {
      color: var(--link-accent-hover);
    }

    .sl-markdown-content code:not(:where(pre *, .not-content *)) {
      background-color: var(--plain-inline-code-bg);
      border: 0;
      border-radius: 4px;
      color: var(--plain-inline-code-text);
      display: inline-block;
      margin-block: 0;
      padding: 3px 6px;
      font-size: 0.81em;
      font-weight: 300;
    }

    .sl-markdown-content .starlight-aside--tip code:not(:where(pre *, .not-content *)) {
      background-color: var(--blue-hover);
      color: var(--surface-raised);
    }

    .sl-markdown-content .starlight-aside--note code:not(:where(pre *, .not-content *)) {
      background-color: var(--info-inline-code-bg);
      color: var(--text);
    }

    .sl-markdown-content .starlight-aside--caution code:not(:where(pre *, .not-content *)),
    .sl-markdown-content .starlight-aside--danger code:not(:where(pre *, .not-content *)) {
      background-color: var(--warn-inline-code-bg);
      color: var(--warn-inline-code-text);
    }

    .sl-markdown-content pre:not(:where(.not-content *)),
    .sl-markdown-content .expressive-code .frame,
    .sl-markdown-content .expressive-code .frame pre,
    .sl-markdown-content .expressive-code .frame pre code {
      background-color: var(--code-block-bg) !important;
    }

    .sl-markdown-content pre:not(:where(.not-content *)) {
      border: 0;
      border-radius: var(--radius);
      padding: 20px 24px;
      line-height: 1.7;
    }

    .sl-markdown-content .expressive-code .frame {
      border: 0 !important;
      border-radius: var(--radius) !important;
      box-shadow: none !important;
      overflow: hidden;
    }

    .sl-markdown-content .expressive-code .frame .header {
      display: none !important;
    }

    .sl-markdown-content .expressive-code .frame pre {
      border: 0 !important;
      border-radius: var(--radius) !important;
      line-height: 1.7 !important;
      margin: 0 !important;
      padding: 20px 24px !important;
      position: relative;
    }

    .sl-markdown-content .expressive-code .frame pre code {
      display: block;
      padding-inline-end: 56px;
    }

    .sl-markdown-content .expressive-code .frame .copy {
      display: none;
    }

    .sl-markdown-content .expressive-code .frame pre[data-language]::before {
      color: var(--code-lang-label);
      content: attr(data-language);
      font-size: 0.75rem;
      font-weight: 500;
      inset-inline-end: 16px;
      line-height: 1;
      pointer-events: none;
      position: absolute;
      text-transform: lowercase;
      top: 12px;
      z-index: 1;
    }

    .sl-markdown-content starlight-tabs {
      border-radius: var(--radius);
      display: block;
      overflow: hidden;
    }

    .sl-markdown-content starlight-tabs .tablist-wrapper {
      background: var(--install-tabs-bg);
      border: 0;
      box-shadow: inset 0 -1px var(--vp-code-tab-divider);
      overflow-x: auto;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='tablist'] {
      display: flex;
      gap: 0;
      list-style: none;
      margin: 0;
      min-width: max-content;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='presentation'] {
      margin: 0;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='tab'] {
      border-bottom: 1px solid transparent;
      color: var(--vp-code-tab-text-color);
      display: inline-block;
      flex-shrink: 0;
      font-size: 0.875rem;
      font-weight: 400;
      line-height: 48px;
      padding-inline: 12px;
      position: relative;
      text-decoration: none;
      transition: color 250ms;
      white-space: nowrap;
    }

    .sl-markdown-content starlight-tabs [role='tab']::after {
      background-color: transparent;
      border-radius: 2px;
      bottom: -1px;
      content: '';
      height: 2px;
      inset-inline: 8px;
      position: absolute;
      transition: background-color 250ms;
      z-index: 1;
    }

    .sl-markdown-content starlight-tabs [role='tab']:hover,
    .sl-markdown-content starlight-tabs [role='tab']:focus-visible {
      color: var(--vp-code-tab-active-text-color);
    }

    .sl-markdown-content starlight-tabs [role='tab']:hover::after,
    .sl-markdown-content starlight-tabs [role='tab']:focus-visible::after,
    .sl-markdown-content starlight-tabs [role='tab'][aria-selected='true']::after {
      background-color: var(--brand);
    }

    .sl-markdown-content starlight-tabs [role='tab'][aria-selected='true'] {
      color: var(--vp-code-tab-active-text-color);
    }

    .sl-markdown-content starlight-tabs [role='tabpanel'] {
      margin-top: 0;
    }

    .sl-markdown-content starlight-tabs [role='tabpanel'] > .expressive-code .frame {
      border-start-end-radius: 0 !important;
      border-start-start-radius: 0 !important;
    }

    .sidebar-content ul ul li {
      border-inline-start: 0;
      margin-inline-start: 0;
      padding-inline-start: 0;
    }

    .sidebar-content a {
      position: relative;
      border-radius: 0;
      color: var(--vp-code-tab-text-color);
      padding-inline-start: 18px;
      text-decoration: none;
      transition: color 250ms;
      font-weight: 400;
    }

    .sidebar-content a::before {
      content: '';
      position: absolute;
      inset-inline-start: 0;
      top: 0.45rem;
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background-color: var(--sidebar-marker-bg);
      opacity: 0;
      transition: opacity 250ms;
    }

    .sidebar-content a:hover,
    .sidebar-content a:focus-visible {
      color: var(--link-accent-hover);
    }

    .sidebar-content a:hover::before,
    .sidebar-content a:focus-visible::before,
    .sidebar-content a[aria-current='page']::before {
      opacity: 1;
    }

    .sidebar-content a[aria-current='page'],
    .sidebar-content a[aria-current='page']:hover,
    .sidebar-content a[aria-current='page']:focus-visible {
      background-color: transparent;
      color: var(--link-accent-hover);
      font-weight: 400;
    }

    .sidebar-content .group-label .large,
    .sidebar-content summary .large {
      color: var(--text);
      font-weight: 300;
      transition: color 150ms;
    }

    .sidebar-content summary:hover .large,
    .sidebar-content summary:focus-visible .large {
      color: var(--link-accent-hover);
    }

    .sidebar-content .caret {
      color: var(--vp-code-tab-text-color);
      transition: color 250ms, transform 0.2s ease-in-out;
    }

    .sidebar-content summary:hover .caret,
    .sidebar-content summary:focus-visible .caret {
      color: var(--link-accent-hover);
    }
  }
</style>
