---
import Default from '@astrojs/starlight/components/PageFrame.astro';
import SiteFooter from './SiteFooter.astro';
---

<Default {...Astro.props}>
  <slot name="header" slot="header" />
  <slot name="sidebar" slot="sidebar" />
  <slot />
</Default>

<div class="print:hidden">
  <script is:inline>
    document.documentElement.classList.toggle(
      'dark',
      document.documentElement.dataset.theme === 'dark'
    );
  </script>
  <SiteFooter />
</div>

<style is:global>
  @layer starlight.core {
    .page > header.header {
      border-bottom-color: transparent;
    }

    .content-panel + .content-panel {
      border-top: 0;
    }

    @media (min-width: 50rem) {
      .sidebar-pane {
        border-inline-end: 0 !important;
        background-color: var(--bg);
      }
    }

    @media (min-width: 72rem) {
      .content-panel {
        border-inline-end: 0 !important;
      }

      .right-sidebar {
        border-inline-start: 0 !important;
      }
    }

    .sidebar-content {
      background-color: transparent;
    }

    .sl-markdown-content a:not(:where(.not-content *)) {
      color: var(--link-accent);
      text-decoration: none;
      transition: color 150ms;
    }

    .sl-markdown-content a:hover:not(:where(.not-content *)),
    .sl-markdown-content a:focus-visible:not(:where(.not-content *)) {
      color: var(--link-accent-hover);
    }

    .sidebar-content ul ul li {
      border-inline-start: 1px solid var(--tree-line);
      margin-inline-start: 0.6rem;
      padding-inline-start: 0;
    }

    .sidebar-content a {
      position: relative;
      border-radius: 0;
      color: var(--vp-code-tab-text-color);
      padding-inline-start: 14px;
      text-decoration: none;
      transition: color 250ms;
      font-weight: 400;
    }

    .sidebar-content a::before {
      content: '';
      position: absolute;
      inset-inline-start: -3px;
      top: 50%;
      width: 5px;
      height: 5px;
      border-radius: 999px;
      background:
        radial-gradient(circle, var(--tree-line) 0 60%, transparent 61%),
        var(--bg);
      opacity: 0;
      transform: translateY(-50%);
      transition: opacity 250ms;
    }

    .sidebar-content a:hover,
    .sidebar-content a:focus-visible {
      color: var(--link-accent-hover);
    }

    .sidebar-content a:hover::before,
    .sidebar-content a:focus-visible::before,
    .sidebar-content a[aria-current='page']::before {
      opacity: 1;
    }

    .sidebar-content a[aria-current='page'],
    .sidebar-content a[aria-current='page']:hover,
    .sidebar-content a[aria-current='page']:focus-visible {
      background-color: transparent;
      color: var(--link-accent-hover);
      font-weight: 400;
    }

    .sidebar-content .group-label .large,
    .sidebar-content summary .large {
      color: var(--text);
      font-weight: 300;
      transition: color 150ms;
    }

    .sidebar-content summary:hover .large,
    .sidebar-content summary:focus-visible .large {
      color: var(--link-accent-hover);
    }

    .sidebar-content .caret {
      color: var(--vp-code-tab-text-color);
      transition: color 250ms, transform 0.2s ease-in-out;
    }

    .sidebar-content summary:hover .caret,
    .sidebar-content summary:focus-visible .caret {
      color: var(--link-accent-hover);
    }
  }

  @layer starlight.components {
    .starlight-aside {
      border: 1px solid transparent !important;
      border-inline-start: 1px solid transparent !important;
      border-radius: 8px;
      font-size: var(--bubble-font-size);
      line-height: 24px;
      padding: 16px 16px 8px;
    }

    .starlight-aside p {
      line-height: 24px;
      margin: 8px 0;
    }

    .starlight-aside p:first-child {
      margin-top: 0;
    }

    .starlight-aside .starlight-aside__title {
      font-size: var(--bubble-font-size);
      font-weight: 600;
      line-height: 24px;
      margin: 0;
    }

    .starlight-aside__title + .starlight-aside__content {
      margin-top: 8px;
    }

    .starlight-aside__content > :last-child {
      margin-bottom: 0;
    }

    .starlight-aside__icon {
      display: none;
    }

    .starlight-aside a {
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
      transition: color 250ms ease;
    }

    .starlight-aside--tip {
      background-color: var(--bubble-tip-bg) !important;
      border-color: var(--bubble-tip-border) !important;
      color: var(--bubble-tip-text);
    }

    .starlight-aside--tip .starlight-aside__title {
      color: var(--bubble-tip-text);
      display: block;
      font-size: 0;
      gap: 0;
      line-height: 24px;
    }

    .starlight-aside--tip a {
      color: var(--bubble-tip-accent);
    }

    .starlight-aside--tip .starlight-aside__title::after {
      content: 'TIP';
      color: var(--bubble-tip-text);
      font-size: var(--bubble-font-size);
      line-height: 24px;
    }

    .starlight-aside--tip a:hover,
    .starlight-aside--tip a:focus-visible {
      color: var(--bubble-tip-accent-hover);
    }

    .starlight-aside--note {
      background-color: var(--bubble-info-bg) !important;
      border-color: var(--bubble-info-border) !important;
      color: var(--bubble-info-text);
    }

    .starlight-aside--note .starlight-aside__title {
      color: var(--bubble-info-text);
    }

    .starlight-aside--note a {
      color: var(--bubble-info-accent);
    }

    .starlight-aside--note .starlight-aside__title {
      display: block;
      font-size: 0;
      gap: 0;
      line-height: 24px;
    }

    .starlight-aside--note .starlight-aside__title::after {
      content: 'INFO';
      color: var(--bubble-info-text) !important;
      font-size: var(--bubble-font-size);
      line-height: 24px;
    }

    .starlight-aside--note a:hover,
    .starlight-aside--note a:focus-visible {
      color: var(--bubble-info-accent-hover);
    }

    .starlight-aside--caution,
    .starlight-aside--danger {
      background-color: var(--bubble-warning-bg) !important;
      border-color: var(--bubble-warning-border) !important;
      color: var(--bubble-warning-text);
    }

    .starlight-aside--caution .starlight-aside__title,
    .starlight-aside--caution a,
    .starlight-aside--danger .starlight-aside__title,
    .starlight-aside--danger a {
      color: var(--bubble-warning-accent);
    }

    .starlight-aside--caution .starlight-aside__title {
      color: var(--bubble-warning-text);
      display: block;
      font-size: 0;
      gap: 0;
      line-height: 24px;
    }

    .starlight-aside--caution .starlight-aside__title::after {
      content: 'WARNING';
      color: var(--bubble-warning-text);
      font-size: var(--bubble-font-size);
      line-height: 24px;
    }

    .starlight-aside--caution a:hover,
    .starlight-aside--caution a:focus-visible,
    .starlight-aside--danger a:hover,
    .starlight-aside--danger a:focus-visible {
      color: var(--bubble-warning-accent-hover);
    }

    :root:not([data-theme='dark']) .starlight-aside--tip a,
    :root:not([data-theme='dark']) .starlight-aside--note a,
    :root:not([data-theme='dark']) .starlight-aside--caution a,
    :root:not([data-theme='dark']) .starlight-aside--danger a {
      font-weight: inherit;
      text-decoration: none;
    }
  }

  @layer starlight.content {
    .sl-markdown-content code:not(:where(pre *, .not-content *)) {
      background-color: var(--plain-inline-code-bg);
      border: 0;
      border-radius: 4px;
      color: var(--plain-inline-code-text);
      display: inline-block;
      font-family: var(--code-font-stack);
      font-size: 0.81em;
      font-weight: 300;
      margin-block: 0;
      padding: 3px 6px;
    }

    .sl-markdown-content .starlight-aside code:not(:where(pre *, .not-content *)) {
      font-size: var(--bubble-code-font-size);
      font-weight: 400;
    }

    .sl-markdown-content .starlight-aside--tip code:not(:where(pre *, .not-content *)) {
      background-color: var(--bubble-tip-code-bg);
      color: var(--bubble-tip-code-text);
    }

    .sl-markdown-content .starlight-aside--note code:not(:where(pre *, .not-content *)) {
      background-color: var(--bubble-info-code-bg);
      color: var(--bubble-info-code-text);
    }

    .sl-markdown-content .starlight-aside--caution code:not(:where(pre *, .not-content *)),
    .sl-markdown-content .starlight-aside--danger code:not(:where(pre *, .not-content *)) {
      background-color: var(--bubble-warning-code-bg);
      color: var(--bubble-warning-code-text);
    }

    .sl-markdown-content pre:not(:where(.not-content *)),
    .sl-markdown-content .expressive-code .frame,
    .sl-markdown-content .expressive-code .frame pre,
    .sl-markdown-content .expressive-code .frame pre code {
      background-color: var(--code-block-bg) !important;
    }

    .sl-markdown-content pre:not(:where(.not-content *)) {
      border: 0;
      border-radius: var(--radius);
      font-family: var(--code-font-stack);
      font-size: 14px;
      line-height: 1.7;
      padding: 20px 24px;
    }

    .sl-markdown-content .expressive-code .frame {
      border: 0 !important;
      border-radius: var(--radius) !important;
      box-shadow: none !important;
      overflow: hidden;
    }

    .sl-markdown-content .expressive-code .frame .header {
      display: none !important;
    }

    .sl-markdown-content .expressive-code .frame pre {
      border: 0 !important;
      border-radius: var(--radius) !important;
      -moz-osx-font-smoothing: auto;
      -webkit-font-smoothing: auto;
      font-family: var(--code-font-stack) !important;
      font-size: 14px !important;
      font-weight: 300 !important;
      line-height: 1.7 !important;
      margin: 0 !important;
      padding: 20px 24px !important;
      position: relative;
    }

    .sl-markdown-content .expressive-code .frame pre code {
      display: block;
      -moz-osx-font-smoothing: auto;
      -webkit-font-smoothing: auto;
      font-family: var(--code-font-stack) !important;
      font-weight: 300 !important;
      line-height: 1.7 !important;
      padding: 0 !important;
    }

    .sl-markdown-content .expressive-code .ec-line .code {
      border-inline-start: 0 !important;
      padding-inline: 0 !important;
      text-indent: 0 !important;
    }

    .sl-markdown-content .expressive-code .frame .copy {
      display: none !important;
    }

    .sl-markdown-content .expressive-code .frame pre[data-language]::before {
      color: var(--code-lang-label);
      content: attr(data-language);
      font-size: 0.75rem;
      font-weight: 500;
      inset-inline-end: 16px;
      line-height: 1;
      pointer-events: none;
      position: absolute;
      text-transform: lowercase;
      top: 12px;
      z-index: 1;
    }
  }

  @layer starlight.components {
    .sl-markdown-content starlight-tabs {
      border-radius: var(--radius);
      display: block;
      overflow: hidden;
    }

    .sl-markdown-content starlight-tabs .tablist-wrapper {
      background: var(--install-tabs-bg);
      border: 0;
      box-shadow: inset 0 -1px var(--vp-code-tab-divider);
      overflow-x: auto;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='tablist'] {
      border-bottom: 0;
      display: flex;
      gap: 0;
      list-style: none;
      margin: 0;
      min-width: max-content;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='presentation'] {
      margin: 0;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs .tab > [role='tab'] {
      box-shadow: none;
      border-radius: 0;
      font-weight: 400;
    }

    .sl-markdown-content starlight-tabs [role='tab'] {
      border-bottom: 1px solid transparent;
      color: var(--vp-code-tab-text-color);
      display: inline-block;
      flex-shrink: 0;
      font-size: 0.875rem;
      font-weight: 400;
      line-height: 20px;
      padding-block: 8px;
      padding-inline: 12px;
      position: relative;
      text-decoration: none;
      transition: color 250ms;
      white-space: nowrap;
    }

    .sl-markdown-content starlight-tabs [role='tab']::after {
      background-color: transparent;
      border-radius: 2px;
      bottom: -1px;
      content: '';
      height: 2px;
      inset-inline: 8px;
      position: absolute;
      transition: background-color 250ms;
      z-index: 1;
    }

    .sl-markdown-content starlight-tabs [role='tab']:hover,
    .sl-markdown-content starlight-tabs [role='tab']:focus-visible {
      color: var(--vp-code-tab-active-text-color);
    }

    .sl-markdown-content starlight-tabs [role='tab']:hover::after,
    .sl-markdown-content starlight-tabs [role='tab']:focus-visible::after,
    .sl-markdown-content starlight-tabs [role='tab'][aria-selected='true']::after {
      background-color: var(--brand);
    }

    .sl-markdown-content starlight-tabs [role='tab'][aria-selected='true'] {
      color: var(--vp-code-tab-active-text-color);
    }

    .sl-markdown-content starlight-tabs .tablist-wrapper ~ [role='tabpanel'],
    .sl-markdown-content starlight-tabs [role='tabpanel'] {
      border: 0;
      border-radius: 0;
      margin-top: 0;
      padding: 0;
    }

    .sl-markdown-content starlight-tabs [role='tabpanel'] .expressive-code .frame {
      border-start-end-radius: 0 !important;
      border-start-start-radius: 0 !important;
      border-end-end-radius: var(--radius) !important;
      border-end-start-radius: var(--radius) !important;
    }
  }
</style>
