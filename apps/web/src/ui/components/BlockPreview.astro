---
interface Props {
  name: string;
  renderedHtml: string;
  code: string;
  codeHtml: string;
  height?: number;
}

const { name, renderedHtml, code, codeHtml, height = 200 } = Astro.props;
const previewId = `block-preview-${name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<div
  class="block-preview mb-8 overflow-hidden rounded-[6px] border border-gray-200 bg-white dark:border-gray-800 dark:bg-black"
  data-block-preview={previewId}
>
  <div class="flex items-center justify-between border-b border-gray-200 bg-gray-50 px-4 py-2 dark:border-gray-700 dark:bg-gray-800">
    <h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200">{name}</h3>
    <div class="flex gap-1 rounded-[6px] bg-gray-200 p-1 dark:bg-gray-700" role="tablist">
      <button
        class="block-preview-tab block-preview-tab-active"
        type="button"
        role="tab"
        aria-selected="true"
        data-block-tab="preview"
      >
        Preview
      </button>
      <button
        class="block-preview-tab"
        type="button"
        role="tab"
        aria-selected="false"
        data-block-tab="code"
      >
        Code
      </button>
    </div>
  </div>

  <div style={`height: ${height}px`}>
    <div class="h-full bg-white p-6 dark:bg-gray-900" data-block-panel="preview">
      <iframe
        srcdoc={`<!DOCTYPE html><html><head><style>body{margin:0;padding:16px;font-family:system-ui,sans-serif;background:#fff;}</style></head><body>${renderedHtml}</body></html>`}
        class="h-full w-full rounded border-0 bg-white"
        title={`Preview: ${name}`}
      />
    </div>

    <div class="code-panel relative hidden h-full" data-block-panel="code">
      <button
        class="copy-code-button absolute right-2 top-2 z-10"
        type="button"
        data-copy-block-code
      >
        Copy
      </button>
      <textarea class="hidden" data-block-code-source>{code}</textarea>
      <div
        class="code-scroll h-full overflow-auto"
        set:html={codeHtml}
      />
    </div>
  </div>
</div>

<script is:inline>
  document.querySelectorAll("[data-block-preview]").forEach((preview) => {
    if (preview.dataset.initialized) return;
    preview.dataset.initialized = "true";

    const tabs = preview.querySelectorAll("[data-block-tab]");
    const panels = preview.querySelectorAll("[data-block-panel]");
    const copyButton = preview.querySelector("[data-copy-block-code]");
    const codeSource = preview.querySelector("[data-block-code-source]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const activeTab = tab.dataset.blockTab;

        tabs.forEach((item) => {
          const isActive = item.dataset.blockTab === activeTab;
          item.classList.toggle("block-preview-tab-active", isActive);
          item.setAttribute("aria-selected", String(isActive));
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.dataset.blockPanel !== activeTab);
        });
      });
    });

    copyButton?.addEventListener("click", async () => {
      if (!codeSource?.value) return;

      await navigator.clipboard.writeText(codeSource.value);
      copyButton.textContent = "Copied!";
      setTimeout(() => {
        copyButton.textContent = "Copy";
      }, 2000);
    });
  });
</script>

<style>
  .block-preview-tab {
    border-radius: 4px;
    color: rgb(75 85 99);
    font-size: 12px;
    font-weight: 500;
    padding: 4px 12px;
    transition: color 150ms ease, background-color 150ms ease;
  }

  .block-preview-tab:hover {
    color: rgb(17 24 39);
  }

  .block-preview-tab-active {
    background-color: #fff;
    color: rgb(17 24 39);
  }

  .block-preview {
    --astro-code-background: var(--astro-code-color-background);
    --astro-code-color-text: #414141;
    --astro-code-color-background: transparent;
    --astro-code-foreground: var(--astro-code-color-text);
    --astro-code-token-constant: #1976d2;
    --astro-code-token-string: #22863a;
    --astro-code-token-comment: #aaa;
    --astro-code-token-keyword: #d32f2f;
    --astro-code-token-parameter: #ff9800;
    --astro-code-token-function: #6f42c1;
    --astro-code-token-string-expression: #22863a;
    --astro-code-token-punctuation: #212121;
    --astro-code-token-link: #22863a;
  }

  .code-panel {
    background-color: #fafafa;
  }

  .copy-code-button {
    background: #f5f5f5;
    border: 1px solid #e0e1e3;
    border-radius: 2px;
    color: #111827;
    font-size: 13px;
    padding: 4px 12px;
    transition:
      background-color 150ms ease,
      border-color 150ms ease;
  }

  .copy-code-button:hover {
    background: #eeeeee;
    border-color: #d1d5db;
  }

  .code-scroll :global(pre) {
    background-color: #fafafa !important;
    border: 1px solid rgb(228 228 229);
    border-radius: 2px;
    font-family:
      Menlo,
      ui-monospace,
      SFMono-Regular,
      Monaco,
      Consolas,
      Liberation Mono,
      Courier New,
      monospace;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.25rem;
    margin: 0;
    min-height: 100%;
    overflow-x: auto;
    padding: 1rem 0;
    tab-size: 2;
    -webkit-font-smoothing: auto;
  }

  .code-scroll :global(code) {
    background: none !important;
    border-style: none !important;
    display: grid;
    line-height: 1.25rem;
    min-width: 100%;
    padding: 0 !important;
  }

  .code-scroll :global(.line) {
    display: block;
    min-height: 1.25rem;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  html.dark .block-preview-tab {
    color: rgb(156 163 175);
  }

  html.dark .block-preview {
    --astro-code-color-text: #d1d1d1;
    --astro-code-token-constant: #79b8ff;
    --astro-code-token-string: #ffab70;
    --astro-code-token-comment: #6b737c;
    --astro-code-token-keyword: #f97583;
    --astro-code-token-parameter: #ff9800;
    --astro-code-token-function: #b392f0;
    --astro-code-token-string-expression: #4bb74a;
    --astro-code-token-punctuation: #bbb;
    --astro-code-token-link: #ffab70;
  }

  html.dark .block-preview-tab:hover,
  html.dark .block-preview-tab-active {
    color: #fff;
  }

  html.dark .block-preview-tab-active {
    background-color: rgb(75 85 99);
  }

  html.dark .code-panel,
  html.dark .code-scroll :global(pre) {
    background-color: #1a1a1a !important;
  }

  html.dark .code-scroll :global(pre) {
    border-color: #292929;
  }

  html.dark .copy-code-button {
    background-color: #141414;
    border-color: #292929;
    color: #c4c5c6;
  }

  html.dark .copy-code-button:hover {
    background-color: #1f1f1f;
    border-color: #3a3a3a;
  }
</style>
