<style>
  .header-control {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: #6b7280;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .header-control:hover {
    background-color: #f3f4f6;
    color: #374151;
  }

  html.dark .header-control {
    color: #9ca3af;
  }

  html.dark .header-control:hover {
    background-color: #1f2937;
    color: #d1d5db;
  }

  .theme-toggle-icon {
    width: 20px;
    height: 20px;
  }

  .header-control svg {
    flex-shrink: 0;
  }

  .github-control {
    gap: 6px;
  }

  .github-stars-count {
    font-size: 12px;
    font-weight: 500;
  }
</style>

<script>
  import { initDiscordTooltip, initHomepageThemeToggle } from "@components/theme-toggle";

  const fetchGitHubStars = async () => {
    const githubStarsElement = document.getElementById("github-stars");

    if (!githubStarsElement) return;

    try {
      const response = await fetch("https://api.github.com/repos/shellscape/jsx-email");

      if (!response.ok) {
        githubStarsElement.remove();
        return;
      }

      const data = await response.json();
      const formattedCount = new Intl.NumberFormat("en-US", {
        notation: data.stargazers_count >= 1000 ? "compact" : "standard",
        maximumFractionDigits: 1,
      }).format(data.stargazers_count);

      githubStarsElement.textContent = formattedCount;
    } catch (error) {
      console.error("Error fetching GitHub stars:", error);
      githubStarsElement.remove();
    }
  };

  document.addEventListener("astro:page-load", () => {
    initHomepageThemeToggle();
    initDiscordTooltip();
    fetchGitHubStars();
  });
</script>

<style is:global>
  .tippy-box[data-theme~="jsx-email"] {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.08),
      0 4px 6px -4px rgb(0 0 0 / 0.08);
    color: #374151;
    font-size: 12px;
    font-weight: 500;
    line-height: 1;
    padding: 2px 4px;
  }

  html.dark .tippy-box[data-theme~="jsx-email"] {
    background-color: #111827;
    border-color: #1f2937;
    color: #e5e7eb;
  }

  .tippy-box[data-theme~="jsx-email"] > .tippy-content {
    padding: 4px 6px;
  }
</style>
