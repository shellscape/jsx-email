{
  "name": "repo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "bootstrap": "./shared/bootstrap.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@dot/versioner": "^0.4.3",
    "@moonrepo/cli": "1.41.7",
    "@swc/core": "^1.3.91",
    "@swc/helpers": "^0.5.2",
    "@types/node": "25.0.8",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "create-mail": "workspace:^",
    "gh-pages": "^6.0.0",
    "happy-dom": "^20.1.0",
    "husky": "^9.1.7",
    "jsx-email": "workspace:^",
    "lint-staged": "16.2.7",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "^1.1.1",
    "ts-node": "10.9.2",
    "typescript": "catalog:",
    "vitest": "^4.0.17"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --format stylish --fix",
      "oxfmt --write"
    ],
    "**/(package|tsconfig(.*)?).json": [
      "oxfmt --write"
    ],
    "(pnpm-workspace|.github/**/*).{yml,yaml}": [
      "oxfmt --write"
    ],
    "*package.json": [
      "oxfmt --write"
    ],
    "((.github/**/*)|(docs/**/*)|(web/**/*.md)|(README|CHANGELOG)|(**/(README|CHANGELOG))).md": [
      "oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "react-router-dom": "6.16.0",
      "vite": "^7.3.1"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
