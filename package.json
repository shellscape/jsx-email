{
  "name": "repo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "bootstrap": "./shared/bootstrap.sh",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@dot/versioner": "^0.4.3",
    "@moonrepo/cli": "1.41.7",
    "@swc/core": "^1.15.11",
    "@swc/helpers": "^0.5.18",
    "@types/node": "25.2.0",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "create-jsx-email": "workspace:*",
    "csstype": "3.2.3",
    "eslint-config-shellscape": "^6.0.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.5.0",
    "husky": "^9.1.7",
    "jsx-email": "workspace:*",
    "lint-staged": "16.2.7",
    "rimraf": "^6.1.2",
    "ts-node": "10.9.2",
    "tshy": "^3.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --cache"
    ],
    "**/(package|tsconfig(.*)?).json": [
      "prettier --write"
    ],
    "(pnpm-workspace|.github/**/*).{yml,yaml}": [
      "prettier --write"
    ],
    "*package.json": [
      "prettier --write --plugin=prettier-plugin-package"
    ],
    "((.github/**/*)|(docs/**/*)|(web/**/*.md)|(README|CHANGELOG)|(**/(README|CHANGELOG))).md": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.6",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.11",
      "@types/react-dom": "19.2.3",
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "react-router-dom": "6.16.0"
    }
  }
}
